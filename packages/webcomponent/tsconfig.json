{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "@floatboat/nexus-core": ["../core/src"]
    }
  },
  "include": ["src"]
}
